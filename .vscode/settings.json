{
    "files.exclude": {
        "**/*.md": true,
        "**/README.md": true,
        "**/IMAGE_PATHS_ORGANIZATION.md": true,
        "**/PHOTOGRAPHY_PATHS.md": true,
        "**/GRAPHIC_DESIGN_PATHS.md": true,
        "**/PAGE_BY_PAGE_PATHS.md": true,
        "**/PAGE_ORGANIZATION.md": true,
        "**/COMPLETE_PAGE_ORGANIZATION.md": true,
        "**/.DS_Store": true,
        "**/Thumbs.db": true,
        "**/public/": true,
        "**/.vercel/": true,
        "**/vercel.json": true,
        "**/.vercelignore": true,
        "**/build.js": true,
        "**/node_modules/": true,
        "**/package-lock.json": true,
        "**/yarn.lock": true,
        "**/*.log": true,
        "**/images/": true,
        "**/*.jpg": true,
        "**/*.jpeg": true,
        "**/*.png": true,
        "**/*.gif": true,
        "**/*.svg": true,
        "**/*.webp": true,
        "**/*.avif": true,
        "**/favicon.svg": true,
        "**/favicon.html": true,
        "**/LICENSE": true,
        "**/CNAME": true
    },
    "files.associations": {
        "*.html": "html",
        "*.css": "css",
        "*.js": "javascript"
    },
    "explorer.fileNesting.enabled": true,
    "explorer.fileNesting.patterns": {
        "*.html": "${capture}.css, ${capture}.js",
        "*.css": "${capture}.js",
        "*.js": "${capture}.css"
    },
    "search.exclude": {
        "**/node_modules": true,
        "**/public": true,
        "**/.vercel": true,
        "**/images": true,
        "**/*.md": true
    }
}
